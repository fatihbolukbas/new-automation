{
    "default": {
      "paths": ["tests/feature/**/*.feature"],
      "formatOptions": {
        "snippetInterface": "async-await"
      },
      "require": [
        "tests/steps/**/*.ts",
        "hooks/**/*.ts"
      ],
      "requireModule": ["ts-node/register"],
      "format": [
        "progress-bar",
        "html:cucumber-report.html",
        "json:cucumber.json"
      ],
      "parallel": 4
    }
}